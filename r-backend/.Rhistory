plumber::plumb("plumber.R")$run(host = "127.0.0.1", port = 8000)
port <- as.integer(Sys.getenv("PORT", unset = "8000"))
cat(sprintf("[start.R] Iniciando servidor Plumber en 0.0.0.0:%d\n", port))
pr <- plumber::plumb("plumber.R")
pr$run(
host  = "0.0.0.0",
port  = port,
quiet = FALSE
)
